PUBLIC_BASE_URL=https://www.trademyfx.com
ALLOWED_ORIGINS=https://www.trademyfx.com,https://trademyfx.com,http://www.trademyfx.com,http://trademyfx.com,http://127.0.0.1:6400,http://localhost:6400,http://127.0.0.1:5173,http://localhost:5173

# Authentication (optional)
# SESSION_SECRET signs login tokens. If left blank a random secret is generated
# and stored in the local database, so sessions survive restarts automatically.
# Set it explicitly in production to keep tokens valid across redeploys / servers.
# SESSION_SECRET=change-me-to-a-long-random-string
# AUTH_DB_PATH=data/app.db
